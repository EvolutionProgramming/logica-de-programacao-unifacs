Algoritmo "AB_multiplos"

Var
   n1,n2:inteiro

Inicio
   escreval("Escreva um n·mero:")
   leia(n1)
   escreval("Escreva outro n·mero:")
   leia(n2)

   se n1%n2=0 entao
      escreval(n1," ķ m·ltiplo de ",n2)
   senao
      escreval(n1," nŃo ķ m·ltiplo de ",n2)
   fimse

Fimalgoritmo