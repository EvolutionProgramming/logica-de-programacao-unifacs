Algoritmo "Tabuada"

Var
   cont,n,resultado : inteiro



Inicio
   escreval("Digite um n·mero: ")
   leia(n)

   cont <- 0

   enquanto (cont<=10)faca
      resultado <- n*cont
      escreval(n," x ",cont," ķ igual hß ",resultado)
      cont <- cont+1
   fimenquanto



Fimalgoritmo