Algoritmo "2numeros_ascendente"

Var
   n1,n2:inteiro

Inicio
      escreval("Digite o primeiro nśmero")
      leia(n1)
      escreval("Digite o segundo nśmero")
      leia(n2)
      
      se n1<n2 entćo
      escreval(n1, "," ,n2)
      senćo
      escreval(n2, "," ,n1)
      fimse

Fimalgoritmo